[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/HUD.gd" id="1"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1")

[node name="Root" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="TopBar" type="PanelContainer" parent="Root"]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = 84.0
grow_horizontal = 2

[node name="MarginContainer" type="MarginContainer" parent="Root/TopBar"]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 12

[node name="HBoxContainer" type="HBoxContainer" parent="Root/TopBar/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 26

[node name="HealthValue" type="Label" parent="Root/TopBar/MarginContainer/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "100 / 100"

[node name="WaveValue" type="Label" parent="Root/TopBar/MarginContainer/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "第 1 波"

[node name="PrimaryValue" type="Label" parent="Root/TopBar/MarginContainer/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "主武器 READY"

[node name="SecondaryValue" type="Label" parent="Root/TopBar/MarginContainer/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "导弹 6 / 6"

[node name="HintLabel" type="Label" parent="Root"]
layout_mode = 1
anchors_preset = 3
anchor_left = 1.0
anchor_right = 1.0
offset_left = -280.0
offset_top = 96.0
offset_right = -16.0
offset_bottom = 144.0
grow_horizontal = 0
theme_override_font_sizes/font_size = 14
text = "空格射击  Q切换副武器  E使用副武器"
horizontal_alignment = 2

[node name="CenterMessage" type="Label" parent="Root"]
unique_name_in_owner = true
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -180.0
offset_top = -120.0
offset_right = 180.0
offset_bottom = -80.0
grow_horizontal = 2
grow_vertical = 2
theme_override_font_sizes/font_size = 24
horizontal_alignment = 1

[node name="MessageTimer" type="Timer" parent="Root"]
unique_name_in_owner = true
wait_time = 1.25
one_shot = true

[connection signal="timeout" from="Root/MessageTimer" to="." method="_on_message_timer_timeout"]
